---
// Astro template component to wrap the repeated HTML structure around content.
import TemplateReference from "./_HTMLLayout.astro";

const { frontmatter } = Astro.props;

// Markdown frontmatter (YAML) entry to list
// extra metadata to link stylesheets and files.
// ---
// extra-metadata-links:
//  - 
//    # link entry in list
//    # common attributes:
//    # rel=
//    - stylesheet
//    # href=
//    - /test.css
//    # optional other attribute:
//    - disabled=""
//  - ...
// ---
//
let extraMetaLinks = "";
if (Object.hasOwn(frontmatter, "extra-metadata-links")) {
	for (const key in frontmatter["extra-metadata-links"]) {
		const linkEntry = frontmatter["extra-metadata-links"][key];
		console.log(`\nConverting extra metadata link: "${linkEntry}"`);
		
		if (!(linkEntry.propertyIsEnumerable(0) &&
				linkEntry.propertyIsEnumerable(1))) {
			continue;
		}
		
		// Converting entry into HTML here.
		extraMetaLinks += "<link ";
		let attribute = `${linkEntry[0]}`;
		for (let index = 0; index < linkEntry.length; attribute = `${linkEntry[++index]}`) {
			if (index < 2) {
				attribute = (["rel", "href"])[index]+`="${attribute}"`;
			}
			const match = (/^([^= \r\n]+)([=])("[^"\r\n]*")$/).exec(attribute);
			// Will not evaluate both operands if the match evaluated to null.
			if (match !== null && match.length == 4) {
				if (match[1] == "rel" && ["shortcut", "shortcut icon", "icon",
						"bookmark", "external", "nofollow", "noopener",
						"noreferrer", "opener", "tag"].includes(match[3].slice(1,-1))) {
					continue;
				}
				extraMetaLinks += match[0]+" ";
			}
		}
		extraMetaLinks += "/>\n";
	}
}
---
<TemplateReference title={frontmatter.title}>
	<Fragment set:html={extraMetaLinks} slot="extra-metadata" />
	<slot />
</TemplateReference>