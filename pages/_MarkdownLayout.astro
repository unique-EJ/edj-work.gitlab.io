---
// Astro template component to wrap the repeated HTML structure around content.
import TemplateReference from "./_HTMLLayout.astro";

const { frontmatter } = Astro.props;

// Markdown frontmatter (YAML) entry to list the extra stylesheet file names.
let extraStyleSheets = {};
if (Object.hasOwn(frontmatter, "extra-stylesheet-files")) {
	// Convert YAML entry here. < name="extra-metadata" />
	// Test:
	extraStyleSheets = `${frontmatter["extra-stylesheet-files"]}
list[`;
	for (const entry in frontmatter["extra-stylesheet-files"]) {
		extraStyleSheets += `${entry}
`;
	}
	extraStyleSheets += `
]`;
